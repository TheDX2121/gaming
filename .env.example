# Telegram Bot Token from @BotFather
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# MongoDB Atlas URI. Use a NEW rotated password, never the one pasted in chat.
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/telegram_gaming_bot?retryWrites=true&w=majority
MONGO_DB_NAME=telegram_gaming_bot

# Admin panel login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password

# Web panel settings
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=True

# Optional. If missing, it is generated automatically on startup.
# SECRET_KEY=your_random_secret_here
